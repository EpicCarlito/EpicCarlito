---
import "../styles/_base.scss";
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro Basics</title>
    <ClientRouter />
  </head>
  <body>
    <div class="container">
      <slot />
    </div>
  </body>
</html>

<style>
  .container {
    display: grid;
    overflow: hidden;
    height: 100%;
    grid-template-rows: 1fr auto;
  }
</style>

<script is:inline>
  document.addEventListener("pointerdown", (element) => {
    const selected = element.target.closest("[data-tap]");
    if (!selected) return;

    const scale = selected.dataset.tap;
    selected.style.setProperty("--scale", scale);

    selected.classList.remove("tap");
    void selected.offsetWidth;
    selected.classList.add("tap");
  });
</script>
