---
import Header from "../components/header.astro";
import Socials from "../components/socials.astro";

const { pathname } = Astro.url;
---

<div id="windowContainer" class=`${pathname == "/" ? "appearWindow" : ""}` transition:name="window" transition:animate="fade">
  <Header />
  <div id="scrollable" class=`${pathname == "/" ? "appearScrollable" : "forceAppear"}`>
    <slot />
  </div>
  <Socials />
</div>


<style>
  #windowContainer {
    position: relative;
    display: flex;
    visibility: visible;
    overflow: hidden;
    flex-grow: 1;
    flex-direction: column;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, #000, #000, #333, #333);
    background-color: gray;
    background-size: 100% 3px;
    border: 2px var(--white-but-not) solid;
    border-radius: 0.375rem;
    opacity: 1;
    animation: scanlines 55s linear 2s infinite;

    &.appearWindow {
      visibility: hidden;
      height: 0;
      opacity: 0;
      animation: appearWindow 2s ease-in-out 1.3s forwards;
    }
  }

  #scrollable {
    display: flex;
    overflow: hidden scroll;
    flex: 1;
    flex-direction: column;
    min-height: 0;
    padding: 1rem;
    padding-bottom: 4rem;
    opacity: 0;
    overscroll-behavior: none;

    &.appearScrollable {
      animation: appearScroll 2s ease-in-out 8.5s forwards;
    }

    &.forceAppear {
      opacity: 1;
    }
  }

  @keyframes appearWindow {
    to {
      visibility: visible;
      flex-grow: 1;
      opacity: 1;
    }
  }

  @keyframes appearScroll {
    to {
      opacity: 1;
    }
  }

  @keyframes scanlines {
    from {
      background-position: 0 0;
    }

    to {
      background-position: 0 -10px;
    }
  }
</style>
