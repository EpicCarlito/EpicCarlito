---
import { Icon } from "astro-icon/components";
const pages = [
  { name: "Main", icon: "mdi:home", href: "/main", alt: "/" },
  { name: "Music", icon: "mdi:music-note-eighth", href: "/music" },
  { name: "Projects", icon: "mdi:hammer-wrench", href: "/projects" },
];
---
<div class="container" id="header">
  {
    pages.map((page, i) => (
      <>
        <a class="outlineLink" href={page.href} data-href={page.href} data-alt={page.alt ?? ""}>
          <div class="inner">
            <Icon name={page.icon} />
            <h1>{page.name}</h1>
          </div>
        </a>
        {i < pages.length - 1 && <div class="divider" />}
      </>
    ))
  }
</div>

<style>
  .container {
    display: flex;
    flex-direction: row;
    align-items: end;
    width: 100%;
    height: 2.75rem;
    background-color: var(--inner-bg);
    border-bottom: 0.5rem var(--color-bg) solid;

    &.animate {
      animation: slideDownHeader 2s ease-in-out 7.5s forwards;
      transform: translateY(-5rem);
    }
  }

  .inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.25rem;
    margin-left: 1rem;

    h1 {
      font-size: var(--text-sm);
      text-align: center;
      margin-block: 0;
    }
  }

  .divider {
    align-self: center;
    width: 0.175rem;
    height: 50%;
    background-color: darkgray;
    border-radius: 5rem;
  }

  .outlineLink {
    --tabGirth: 0.5rem;

    display: flex;
    align-items: center;
    width: 7rem;
    height: 2rem;
    transition: clip-path 10s ease-in-out;

    &.active {
      background-color: var(--color-bg);
      clip-path: shape(
        from bottom left,
        curve to var(--tabGirth) calc(100% - var(--tabGirth)) with var(--tabGirth) 100%,
        vline to var(--tabGirth),
        curve to calc(var(--tabGirth) * 2) 0 with var(--tabGirth) 0,
        hline to calc(100% - calc(var(--tabGirth) * 2)),
        curve to calc(100% - var(--tabGirth)) var(--tabGirth) with calc(100% - var(--tabGirth)) 0,
        vline to calc(100% - var(--tabGirth)),
        curve to 100% 100% with calc(100% - var(--tabGirth)) 100%
      );
      filter: drop-shadow(3px 3px 5px #000);
    }
  }

  @keyframes slideDownHeader {
    to {
      transform: translateY(0);
    }
  }

  @media (width >= 48rem) {
    .outlineLink {
      width: 10rem;
      height: 1.875rem;
    }
  }
</style>

<script is:inline>
  function initHeader() {
    const pathname = window.location.pathname;
    const header = document.getElementById("header");

    if (pathname === "/") {
      header.classList.add("animate");
    } else {
      header.classList.remove("animate");
    }

    document.querySelectorAll(".outlineLink").forEach((link) => {
      const href = link.dataset.href;
      const alt = link.dataset.alt;
      if (pathname === href || (alt && pathname === alt)) {
        link.classList.add("active");
      } else {
        link.classList.remove("active");
      }
    });
  }

  initHeader();
  document.addEventListener("astro:page-load", initHeader);
</script>