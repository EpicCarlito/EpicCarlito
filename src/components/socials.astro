---
import { Icon } from "astro-icon/components";
// discord instagram github starva
const { pathname } = Astro.url;
---

<div id="socialsContainer" class=`${pathname == "/" ? "animateSocials" : ""}`>
  <div class="container">
    <a
      class="link scaleUp"
      data-tap={1.1}
      href="https://www.instagram.com/epiccarlito/"
    >
      <Icon id="icon" name="mdi:instagram" />
    </a>
    <a
      class="link scaleUp"
      data-tap={1.1}
      href="https://github.com/epiccarlito"
    >
      <Icon id="icon" name="mdi:github" />
    </a>
    <a
      class="link scaleUp"
      data-tap={1.1}
      href="https://www.strava.com/athletes/126999343"
    >
      <Icon id="icon" name="starva" />
    </a>
  </div>
</div>

<style>
  [data-icon] {
    font-size: 2.5rem;
  }

  #socialsContainer {
    position: absolute;
    bottom: 0;
    left: 50%;
    display: flex;
    flex-direction: row;
    gap: 1rem;
    background-color: var(--color-bg);
    border-radius: 1rem 1rem 0 0;
    border-left: 2px var(--white-but-not) solid;
    border-right: 2px var(--white-but-not) solid;
    border-top: 2px var(--white-but-not) solid;
    transform: translateX(-50%);

    &.animateSocials {
      opacity: 0;
      animation: appearSocials 2s ease-in-out 7.5s forwards;
      transform: translateY(5rem) translateX(-50%);
    }
  }

  .container {
    display: flex;
    gap: 0.325rem;
    padding: 0.5rem;
  }

  .link {
    display: inline-flex;
    color: var(--white-but-not);
    transition: transform 300ms ease;
    cursor: pointer;
  }

  link:hover {
    transform: scale(1.2);
  }

  .icon {
    filter: drop-shadow(3px 3px 5px rgb(0 0 0 / 5%));
  }

  @keyframes appearSocials {
    to {
      opacity: 1;
      transform: translateY(0) translateX(-50%);
    }
  }
</style>
